<mxfile host="app.diagrams.net">
  <diagram name="Trang-1" id="VaCFzopAseK1iVyFZj-h">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;flowchart TD\n    %% ==========================================\n    %% 1. TÁC NHÂN (ACTORS)\n    %% ==========================================\n    subgraph Actors [\&quot;👥 1. NGƯỜI DÙNG\&quot;]\n        Learner([Học sinh / Học viên])\n        Admin([Quản trị viên / Giáo viên])\n    end\n\n    %% ==========================================\n    %% 2. GIAO DIỆN NGƯỜI DÙNG (FRONTEND - NEXT.JS)\n    %% ==========================================\n    subgraph Frontend [\&quot;💻 2. FRONTEND (GIAO DIỆN NEXT.JS)\&quot;]\n        \n        subgraph PublicPages [\&quot;Trang Công Khai (Public)\&quot;]\n            UI_Landing[Landing Page\\n(Giới thiệu hệ thống)]\n            UI_Auth_User[Đăng nhập / Đăng ký\\n(Learner)]\n            UI_Auth_Admin[Đăng nhập Admin\\n(/admin/login)]\n        end\n\n        subgraph MainApp [\&quot;Trang Main (Learner Portal)\&quot;]\n            UI_Dashboard[Dashboard\\n(Tiến độ, Streak, Elo)]\n            UI_Profile[Profile / Settings\\n(Quản lý cá nhân)]\n            UI_Quiz[Giao diện Làm bài Quiz\\n(Hiển thị câu hỏi, Gợi ý)]\n            UI_Chatbot[AI Chatbot Assistant\\n(Hỗ trợ giải đáp)]\n        end\n\n        subgraph AdminApp [\&quot;Trang Admin (Admin Portal)\&quot;]\n            UI_AdminDash[Admin Dashboard\\n(Tổng quan hệ thống)]\n            UI_ManageContent[Quản lý Nội dung\\n(Topics, Questions, Import)]\n            UI_ManageUsers[Quản lý Người dùng\\n(Phân quyền, Reset mật khẩu)]\n            UI_Analytics[Thống kê Hệ thống\\n(Báo cáo hiệu suất)]\n        end\n    end\n\n    %% ==========================================\n    %% 3. HỆ THỐNG XỬ LÝ (BACKEND - PYTHON/FASTAPI)\n    %% ==========================================\n    subgraph Backend [\&quot;⚙️ 3. BACKEND (API &amp; AI CORE)\&quot;]\n        \n        subgraph API_Routers [\&quot;API Gateway / Routers\&quot;]\n            API_Auth[Auth Router\\n(Xử lý JWT, Phân quyền)]\n            API_Admin[Admin Router\\n(CRUD Nội dung &amp; Users)]\n            API_Content[Content Router\\n(Truy xuất bài học)]\n            API_Learning[Learning Router\\n(/answer, /recommend)]\n            API_Chat[Chat Router\\n(Giao tiếp LLM)]\n        end\n\n        subgraph AI_Core_Engines [\&quot;AI &amp; Logic Engines\&quot;]\n            Engine_Recommend{Content Recommender}\n            R_P1[Ưu tiên 1: SM-2 Ôn tập]\n            R_P2[Ưu tiên 2: ZPD Elo Mới]\n            R_P3[Ưu tiên 3: Theo Chủ đề]\n            \n            Engine_Answer[Xử lý Đáp án (Answer Processor)]\n            E_Score[1. Logic Chấm điểm đúng/sai]\n            E_Elo[2. Elo Engine (Tính K-Factor)]\n            E_SM2[3. SM-2 Engine (Tính Next Review)]\n            E_Mastery[4. Tính toán Tỉ lệ Mastery]\n            E_Gami[5. Cấp XP &amp; Cập nhật Streak]\n        end\n    end\n\n    %% ==========================================\n    %% 4. CƠ SỞ DỮ LIỆU (DATABASE - SUPABASE/POSTGRESQL)\n    %% ==========================================\n    subgraph Database [\&quot;🗄️ 4. DATABASE (SUPABASE)\&quot;]\n        DB_Users[(Users Table\\nRoles, Overall_Elo, XP)]\n        DB_Content[(Content Tables\\nTopics, Questions, Options)]\n        DB_Mastery[(LearnerMastery\\nMastery_Score)]\n        DB_SM2[(SpacedRepetition\\nInterval, EF, Next_Review)]\n        DB_Log[(Interaction Logs\\nCâu trả lời, Quality, Time)]\n    end\n\n    %% ==========================================\n    %% LIÊN KẾT LUỒNG (CONNECTIONS)\n    %% ==========================================\n\n    %% Luồng Actors -&gt; Frontend\n    Learner --&gt; UI_Landing\n    UI_Landing --&gt; UI_Auth_User\n    UI_Auth_User -- \&quot;Đăng nhập thành công\&quot; --&gt; UI_Dashboard\n    Learner --&gt; UI_Profile\n    Learner --&gt; UI_Chatbot\n    \n    Admin --&gt; UI_Auth_Admin\n    UI_Auth_Admin -- \&quot;Verify JWT\&quot; --&gt; UI_AdminDash\n\n    %% Luồng Admin Frontend -&gt; Backend\n    UI_AdminDash --&gt; UI_ManageContent &amp; UI_ManageUsers &amp; UI_Analytics\n    UI_ManageContent &amp; UI_ManageUsers &amp; UI_Analytics --&gt; API_Admin\n\n    %% Luồng Admin Backend -&gt; Database\n    API_Admin -- \&quot;CRUD (Tạo, Sửa, Xóa)\&quot; --&gt; DB_Content &amp; DB_Users &amp; DB_Log\n\n    %% Luồng Learner Frontend -&gt; Backend\n    UI_Auth_User &amp; UI_Auth_Admin --&gt; API_Auth\n    API_Auth &lt;--&gt; DB_Users\n\n    UI_Chatbot --&gt; API_Chat --&gt; DB_Content\n\n    UI_Dashboard -- \&quot;Yêu cầu bài học (Start)\&quot; --&gt; API_Learning\n    API_Learning --&gt; Engine_Recommend\n    Engine_Recommend --&gt; R_P1 &amp; R_P2 &amp; R_P3\n    R_P1 &amp; R_P2 &amp; R_P3 -- \&quot;Truy xuất DB\&quot; --&gt; DB_Content &amp; DB_SM2\n    Engine_Recommend -- \&quot;Trả dữ liệu câu hỏi\&quot; --&gt; UI_Quiz\n\n    UI_Quiz -- \&quot;Nộp đáp án (Submit)\&quot; --&gt; API_Learning\n    API_Learning --&gt; Engine_Answer\n    Engine_Answer --&gt; E_Score\n    E_Score --&gt; E_Elo &amp; E_SM2 &amp; E_Mastery &amp; E_Gami\n\n    %% Luồng Logic -&gt; Database\n    E_Elo -- \&quot;Cập nhật Learner &amp; Question Elo\&quot; --&gt; DB_Users &amp; DB_Content\n    E_SM2 -- \&quot;Lưu Next_Review_Date, Quality\&quot; --&gt; DB_SM2\n    E_Mastery -- \&quot;Cập nhật Mastery_Score\&quot; --&gt; DB_Mastery\n    E_Gami -- \&quot;Lưu lịch sử, cộng XP\&quot; --&gt; DB_Log &amp; DB_Users\n\n    E_Gami -- \&quot;Phản hồi kết quả\&quot; --&gt; UI_Quiz\n    UI_Quiz -- \&quot;Quay lại\&quot; --&gt; UI_Dashboard\n\n    %% ==========================================\n    %% ĐỊNH DẠNG MÀU SẮC (STYLING)\n    %% ==========================================\n    classDef actor fill:#eceff1,stroke:#607d8b,stroke-width:2px,color:#000;\n    classDef frontend_main fill:#e3f2fd,stroke:#2196f3,stroke-width:2px,color:#000;\n    classDef frontend_admin fill:#ffebee,stroke:#f44336,stroke-width:2px,color:#000;\n    classDef backend_api fill:#fff3e0,stroke:#ff9800,stroke-width:2px,color:#000;\n    classDef backend_logic fill:#f3e5f5,stroke:#9c27b0,stroke-width:2px,color:#000;\n    classDef database fill:#e8f5e9,stroke:#4caf50,stroke-width:2px,color:#000;\n\n    class Learner,Admin actor;\n    class UI_Landing,UI_Auth_User,UI_Dashboard,UI_Profile,UI_Quiz,UI_Chatbot frontend_main;\n    class UI_Auth_Admin,UI_AdminDash,UI_ManageContent,UI_ManageUsers,UI_Analytics frontend_admin;\n    class API_Auth,API_Admin,API_Content,API_Learning,API_Chat backend_api;\n    class Engine_Recommend,R_P1,R_P2,R_P3,Engine_Answer,E_Score,E_Elo,E_SM2,E_Mastery,E_Gami backend_logic;\n    class DB_Users,DB_Content,DB_Mastery,DB_SM2,DB_Log database;&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="YBkgOAatnuThs39eEMf--144">
          <mxCell connectable="0" parent="1" style="group;transparentBounds=1;editIcon=1;lockedGroup=0;groupPadding=20;" vertex="1">
            <mxGeometry as="geometry" />
          </mxCell>
